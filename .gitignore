# ═══════════════════════════════════════════════════════════
# PairDrop - Git Ignore
# BAUER GROUP | CS-PairDrop
# ═══════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# Environment (Secrets)
# ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─────────────────────────────────────────────────────────────
# Certificates (managed by ACME Manager)
# ─────────────────────────────────────────────────────────────
certs/
*.pem
*.crt
*.key

# ─────────────────────────────────────────────────────────────
# IDE
# ─────────────────────────────────────────────────────────────
.vscode/
.idea/
.claude/
*.code-workspace
.history/

# ─────────────────────────────────────────────────────────────
# OS Files
# ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ─────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────
*.log
logs/

# ─────────────────────────────────────────────────────────────
# Temporary Files
# ─────────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*~

# ─────────────────────────────────────────────────────────────
# Node (if any tooling)
# ─────────────────────────────────────────────────────────────
node_modules/
